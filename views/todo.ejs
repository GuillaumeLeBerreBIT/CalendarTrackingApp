<%- include('partials/header.ejs') %>

    <div class="todo-header-container">
        <h1>Todo Lists</h1>

        <div class="center-vertical">
            <input type="search" placeholder="Search task">
        </div>

        <div class="center-vertical">
            <select name="filter" id="filter">
                <option value="all">All Tasks</option>
                <option value="completed">Active</option>
                <option value="active">Completed</option>
                <option value="to-me">Assigned to Me</option>
            </select>
            <button class="btn-new-list" id="btn-new-list">Add New List</button>
        </div>
    </div>

    <!--Show Groups with list items-->
    <div class="group-container">
        <% yourTaskLists.forEach(taskList=> { %>

            <div class="group-card card-shape" data-task-list-id="<%= taskList.taskListInfo.idTl %>"
                data-group-id="<%= taskList.taskListInfo.idG %>">
                <div class="group-header">
                    <input type="hidden">
                    <div class="justify-start">
                        <h3 id="task-list-title">
                            <%= taskList.taskListInfo.title %>
                        </h3>
                        <div class="badge-secondary">
                            <%= taskList.taskListInfo.tag_group %>
                        </div>
                    </div>

                    <div class="header-item">
                        <button class="btn btn-soft add-task-btn" id="add-task-btn"
                            data-task-list-id="<%= taskList.taskListInfo.idTl %>">
                            Add Task
                        </button>
                        <button class="btn btn-soft">...</button>
                    </div>
                </div>

                <p>
                    <%= taskList.taskListInfo.task_list_description %>
                </p>

                <div class="progress-section">
                    <div class="justify-between">
                        <span class="progress-bar-text">Progress</span>
                        <span class="progress-bar-prog">0 of <%= taskList.totalTasks %> completed</span>
                    </div>
                    <div class="progress-container" role="progressbar">
                        <div class="progress"></div>
                    </div>
                </div>

                <div class="task-container" id="task-container">
                    <% if (taskList.taskItems.length !==0) {taskList.taskItems.forEach(t=> { %>
                        <div class="task-card card-shape">
                            <div class="radio-box">
                                <input type="checkbox" class="task-completion" name="task-completion" 
                                 data-task-id="<%= t.task_id%>"
                                <% if (t.is_completed) {%>checked<%}%>>
                            </div>
                            <div class="task-content">
                                <div class="justify-between">
                                    <h4>
                                        <%= t.task_title %>
                                    </h4>
                                    <span class="badge-secondary">
                                        <%= t.priority %>
                                    </span>
                                </div>
                                <p>
                                    <%= t.task_description %>
                                </p>
                                <div>
                                    <span>John Doe</span>
                                    <% if (t?.due_date) {%>
                                        <span>Due Sep 4</span>
                                        <%} else {%>
                                            <span>No deadline</span>
                                            <%} %>
                                </div>
                            </div>
                        </div>
                        <%})} else { %>
                            <div class="task-card card-shape" id="empty-state">
                                <div class="radio-box"></div>
                                <div class="task-content">
                                    <div class="justify-between">
                                        <h4 id="task-title">No Tasks added yet?</h4>
                                        <span id="task-priority"></span>
                                    </div>
                                    <p id="task-description">Let's add some tasks in here</p>
                                    <div>
                                        <span id="task-users"></span>
                                        <span id="task-deadline"></span>
                                    </div>
                                </div>
                            </div>
                            <%}; %>
                </div>
            </div>
            <%}); %>
                <div class="group-card card-shape">
                    <div class="group-header">
                        <div class="justify-start">
                            <h3>Study Tasks</h3>
                            <div class="badge-secondary">Study Group</div>
                        </div>

                        <div class="header-item">
                            <button class="btn btn-soft add-task-btn">Add Task</button>
                            <button class="btn btn-soft">...</button>
                        </div>
                    </div>

                    <p>Tasks for upcoming exams and assignments.</p>

                    <div class="justify-between">
                        <span class="progress-bar">Progress</span>
                        <span class="progress-bar">1 of 2 completed</span>
                    </div>

                    <div class="task-container">
                        <div class="task-card card-shape">
                            <div class="radio-box">
                                <input type="checkbox" name="task-completion" id="task-completion">
                            </div>
                            <div class="task-content">
                                <div class="justify-between">
                                    <h4>Review Chapter 5 - Data Structures</h4>
                                    <span>High</span>
                                </div>
                                <p>
                                    Read and summarize key concepts from the data structures chapter.
                                </p>
                                <div>
                                    <span>John Doe</span>
                                    <span>Due Sep 4</span>
                                </div>
                            </div>
                        </div>
                        <div class="task-card card-shape">
                            <div class="radio-box">
                                <input type="checkbox" name="task-completion" id="task-completion">
                            </div>
                            <div class="task-content">
                                <div class="justify-between">
                                    <h4>Complete Practice Problems</h4>
                                    <span>Medium</span>
                                </div>
                                <p>
                                    Solve problems 1-15 from the textbook.
                                </p>
                                <div>
                                    <span>Jane Smith</span>
                                    <span>Completed Sep 2</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
    </div>

    <div class="modal-overlay" id="modal-overlay-new-list">
        <div class="modal-box">
            <span class="close-btn" id="close-btn">&times;</span>

            <form method="post" action="/createTaskList" class="form-modal" id="task-list-form">

                <div class="flex-column">
                    <label for="task_list_title">Title</label>
                    <input name="title" id="task_list_title" type="text" placeholder="Title" required>
                </div>
                <div class="flex-column">
                    <label for=tag_name>Tag</label>
                    <select name="group-tags" id="tag_name">
                        <% groupTagObj.forEach((t)=> {%>
                            <option value="<%= t.gid %>">
                                <%= t.tag %>
                            </option>
                            <% })%>
                    </select>
                </div>
                <div class="flex-column">
                    <label for="task_list_descr">Description</label>
                    <textarea name="description" id="task_list_descr" rows="5" cols="33"
                        placeholder="Context about the tasks entered in this list."></textarea>
                </div>

                <input type="hidden" name="groups_id" id="groups_id" value="">

                <input type="submit" class="task-list-submit" id="task-list-submit">
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="modal-overlay-new-task">
        <div class="modal-box">
            <span class="close-btn" id="close-btn-task">&times;</span>

            <form action="/createTask" method="post" class="form-modal" id="task-form">

                <div class="flex-column">
                    <label for="">Title</label>
                    <input type="text" name="task_title" class="" id="" placeholder="">
                </div>
                <div class="flex-column">
                    <label for="">Task Description</label>
                    <input type="text" name="task_description" class="" id="" placeholder="">
                </div>
                <div class="flex-column">
                    <label for="">Priority</label>
                    <select type="text" name="priority" class="" id="">
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="flex-column">
                    <label for="">Due Date</label>
                    <input type="date" name="due_date" class="" id="">
                </div>
                <div class="flex-column">
                    <label for="">Assigned To</label>
                    <input type="text" name="assigned_to" class="" id=""
                        placeholder="Need to be select of all users in the group">
                </div>
                <input type="hidden" name="task_list_id" id="task_list_id" value="">
                <input type="submit" class="btn-task-submit" id="btn-task-submit">
            </form>
        </div>
    </div>

    <template id="task-list-template">
        <div class="group-card card-shape">
            <div class="group-header">
                <div class="justify-start">
                    <h3 class="task-list-title"></h3>
                    <div class="badge-secondary task-list-tag"></div>
                </div>
                <div class="header-item">
                    <button class="btn btn-soft add-task-btn">Add Task</button>
                    <button class="btn btn-soft">...</button>
                </div>
            </div>
            <p class="task-list-description"></p>
            <div class="justify-between">
                <span class="progress-bar">Progress</span>
                <span class="progress-bar task-list-progress">0 of 0 completed</span>
            </div>
            <div class="task-container">
                <p class="empty-state" style="text-align: center; color: #999; padding: 20px;">
                    No tasks yet. Click "Add Task" to get started.
                </p>
            </div>
        </div>
    </template>

    <template id="task-template">
        <div class="task-card card-shape">
            <div class="radio-box">
                <input type="checkbox" name="task-completion" id="task-completion">
            </div>
            <div class="task-content">
                <div class="justify-between">
                    <h4 id="task-title"></h4>
                    <span id="task-priority"></span>
                </div>
                <p id="task-description"></p>
                <div>
                    <span id="task-users">John Doe</span>
                    <span id="task-deadline">No deadline</span>
                </div>
            </div>
        </div>
    </template>

    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.18/index.global.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="js/todo.js"></script>
    <%- include('partials/footer.ejs') %>