<%- include('partials/header.ejs') %>

    <div class="todo-header-container">
        <h1>Todo Lists</h1>

        <div class="center-vertical">
            <input type="search" placeholder="Search task">
        </div>

        <div class="center-vertical">
            <select name="filter" id="filter">
                <option value="all">All Tasks</option>
                <option value="completed">Active</option>
                <option value="active">Completed</option>
                <option value="to-me">Assigned to Me</option>
            </select>
            <button>Add New List</button>
        </div>
    </div>

    <!--Show Groups with list items-->
    <div class="group-container">
        <div class="group-card">
            <div class="group-header">
                <h4>Study Tasks</h4>
                <span>Study Group</span>

                <div class="header-item">
                    <button>Add Task</button>
                    <button>...</button>
                </div>
            </div>

            <span>Tasks for upcoming exams and assignments.</span>

            <div>Progress</div>

            <div class="tasks-container">
                <div class="task-card">
                    <div class="radio-box">
                        <input type="radio" name="task-completion" id="task-completion">
                    </div>
                    <div class="task-content">
                        <div>
                            <h4>Review Chapter 5 - Data Structures</h4>
                            <span>High</span>
                        </div>
                        <div>
                            Read and summarize key concepts from the data structures chapter.
                        </div>
                        <div>
                            <div>John Doe</div>
                            <div>Due Sep 4</div>
                        </div>
                    </div>
                </div>
                <div class="task-card">
                    <div>
                        <input type="radio" name="task-completion" id="task-completion">
                    </div>
                    <div class="task-content">
                        <h4>Complete Practice Problems</h4>
                        <span>Medium</span>
                    </div>
                    <div>
                        Solve problems 1-15 from the textbook.
                    </div>
                    <div>
                        <div>Jane Smith</div>
                        <div>Completed Sep 2</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include('partials/footer.ejs') %>