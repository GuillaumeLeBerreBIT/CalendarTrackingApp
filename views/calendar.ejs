<%- include('partials/header.ejs') %>
<body class="app-page">
<%- include('partials/navbar.ejs') %>
<main>
<div class="container-calendar">
    <div id="calendar"></div>

    <!-- Show in a card the upcoming activities -->
    <div class="container-tags card-shape">

        <% Object.entries(groupsTagNames).forEach(t => { 
            const [id, name] = t
            %>
            <div class="calendar-group-tag" data-group-id="<%=id%>">
                <%= name %>
            </div>
        <%})%>
        
    </div>
    <div class="upcoming-container">
        <div class="justify-between upcoming-header">
            <h2>Upcoming Events</h2>
            <button>Add Event</button>
        </div>
        <!-- <div class="overflow-cont"> -->
            <div class="upcoming-list card-shape">
                <!--Insert the Upcoming tasks-->
                
            </div>   
        <!-- </div> -->
    </div>

    <div class="modal-overlay" id="modal-overlay">
        <div class="modal-box hide-scrollbar"> 
            <span class="close-btn" id="close-btn">&times;</span>
            <form class="form-modal" id="form-calendar">
                <div class="flex-column gap-0">
                    <h3>Add Event</h3>
                    <p>Add your events to keep up to date with yout tasks.</p>
                </div>
                <div class="flex-column">
                    <label for="calendar-title">Title</label>
                    <input type="text" name="calendar-title" id="calendar-title" placeholder="Title" required>
                </div>
                <div class="flex-column">
                    <label for="calendar-title">Description</label>
                    <textarea id="calendar-description" name="calendar-description" rows="3" cols="33"
                        placeholder="What is this about?"></textarea>
                </div>
                <div class="justify-start gap-20">
                    <label for="allDay">Whole day?</label>
                    <input type="checkbox" name="allDay"  class="all-day" id="allDay">
                </div>
                <div class="flex-column">
                    <label for="startDate">From</label>
                    <input type="date" name="startDate" id="startDate">
                    <input type="time" name="startTime" id="startTime">
                </div>
                <div class="flex-column">
                    <label for="startDate">To</label>
                    <input type="date" name="endDate" id="endDate">
                    <input type="time" name="endTime" id="endTime">
                </div>
                <%if (groupsTagNames) {%>
                    <div class="flex-column">
                        <label for="tagNames">Groups</label>
                        <select name="tagNames" id="tagNames">
                            <option value="">-- Select a group to link event to --</option>
                            <% Object.entries(groupsTagNames).forEach(entry => { %>
                                <% const [id, tagName] = entry;%>
                                <option value="<%=id%>" data-group-id="<%=id%>"><%=tagName%></option>
                            <%});%>
                        </select>
                    </div>
                <%};%>
                <!--Need to show the users that can be linked to an event when selecting a group.-->
                <div class="flex-column set-display-none" id="select-users-wrapper">
                    <label>Select Participants</label>
                    <div id="participants-container" class="card-shape participants-box">

                    </div>
                </div>
                <input type="hidden" value="">
                <button type="submit">Add Event</button>
            </form>
        </div>
    </div>

    <div class="modal-overlay" id="modal-overlay-event">
        <div class="modal-box-event">
            <div class="event-modal-header">
                <span class="event-modal-label">Event</span>
                <span class="event-close-btn" id="close-btn-event">&times;</span>
            </div>
            <div class="event-modal-title-row">
                <div class="left-border">
                    <h2 class="event-header" id="event-title">Event Title</h2>
                    <span id="group-tag-name"></span>
                </div>
                <div class="event-modal-actions">
                    <button class="btn-icon" id="edit-event" title="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v200h-80v-40H200v400h280v80H200Zm0-560h560v-80H200v80Zm0 0v-80 80ZM560-80v-123l221-220q9-9 20-13t22-4q12 0 23 4.5t20 13.5l37 37q8 9 12.5 20t4.5 22q0 11-4 22.5T903-300L683-80H560Zm300-263-37-37 37 37ZM620-140h38l121-122-18-19-19-18-122 121v38Zm141-141-19-18 37 37-18-19Z"/></svg>
                    </button>
                    <button class="btn-icon btn-icon-danger" id="delete-event" title="Delete">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"/></svg>
                    </button>
                </div>
            </div>
            <div class="event-modal-body">
                <div class="event-info-row">
                    <span class="event-info-label">Start</span>
                    <p id="event-start-date"></p>
                </div>
                <div class="event-info-row" id="event-end-wrapper">
                    <span class="event-info-label">End</span>
                    <p id="event-end-date"></p>
                </div>
                <div class="event-info-row">
                    <span class="event-info-label">People</span>
                    <div class="justify-start gap-5 flex-wrap" id="event-participants"></div>
                </div>
                <div class="event-description-box">
                    <div id="event-description"></div>
                </div>
            </div>
        </div>
    </div>

    <template id="template-upcoming">
        <div class="card-shape group-card">
            <div class="justify-between">
                <h3 id="event-title">Event Title</h3>
                <div class="badge-secondary" id="group-name">Group</div>
            </div>
            <div class="justify-start gap-20" id="event-participants">
            </div>
            <span id="event-description">Description</span>
            <div class="justify-start gap-20">
                <span id="startDate" class="fw-bold">Start Time</span>
                <span id="endDate" class="fw-bold">End Date</span>    
            </div>
        </div>
    </template>

</div>

<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.18/index.global.min.js'></script>
<script src="https://cdn.jsdelivr.net/npm/axios@1.11.0/dist/axios.min.js"></script>
<script src="/js/calendar.js"></script>
<%- include('partials/footer.ejs') %>